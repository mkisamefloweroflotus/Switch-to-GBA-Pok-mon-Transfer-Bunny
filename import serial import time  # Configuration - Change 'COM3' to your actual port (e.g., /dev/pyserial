import serial
import time

# Configuration - Change 'COM3' to your actual port (e.g., /dev/ttyUSB0 on Linux)
SERIAL_PORT = 'COM3' 
BAUD_RATE = 115200

def start_translator():
    try:
        # Initialize the connection to your C++ Hardware Bridge
        gba_bridge = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=1)
        print(f"--- Connected to GBA Bridge on {SERIAL_PORT} ---")
        
        with open("gba_capture_log.txt", "a") as log_file:
            while True:
                if gba_bridge.in_waiting > 0:
                    # Read the raw hex string sent by your C++ code
                    raw_data = gba_bridge.readline().decode('utf-8').strip()
                    
                    if raw_data:
                        timestamp = time.strftime("%H:%M:%S")
                        print(f"[{timestamp}] GBA Signal Received: {raw_data}")
                        
                        # Save to a file for later "Injection" into the Switch
                        log_file.write(f"{timestamp}, {raw_data}\n")
                        log_file.flush() 

    except serial.SerialException as e:
        print(f"Error: Could not open serial port. {e}")
    except KeyboardInterrupt:
        print("\nStopping translator... Data saved to gba_capture_log.txt")
    finally:
        if 'gba_bridge' in locals():
            gba_bridge.close()

if __name__ == "__main__":
    start_translator()
